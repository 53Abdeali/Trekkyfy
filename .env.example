# ======================
# Root Environment File
# ======================
# Copy this file to .env and fill real values.

# Shared DB Settings (used by docker-compose)
POSTGRES_DB=trekkyfy
POSTGRES_USER=trekkyfy
POSTGRES_PASSWORD=trekkyfy

# Backend
BACKEND_PORT=10000
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES_HOURS=10
TOKEN_SALT=trekkyfy-reset-password
DATABASE_URL=postgresql+psycopg://trekkyfy:trekkyfy@localhost:5432/trekkyfy

# CORS
FRONTEND_ORIGINS=http://localhost:3000,https://trekkyfy.vercel.app
SOCKET_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://trekkyfy.vercel.app,*

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000/api
